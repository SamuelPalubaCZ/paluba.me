# Public canonical origin used by Astro and EmDash behind a reverse proxy.
EMDASH_SITE_URL=https://paluba.me
SITE_URL=https://paluba.me

# Production Node listener. Keep it private behind Nginx/Caddy.
HOST=127.0.0.1
PORT=4321
NODE_ENV=production

# Required by Wrangler when using an API token in non-interactive CI/CLI.
CLOUDFLARE_ACCOUNT_ID=
