---
import Base from "../layouts/Base.astro";

const links = [
	{
		label: "Email",
		value: "samuel.paluba@thinkhome.org",
		href: "mailto:samuel.paluba@thinkhome.org",
	},
	{
		label: "GitHub",
		value: "SamuelPalubaCZ",
		href: "https://github.com/SamuelPalubaCZ",
	},
	{
		label: "LinkedIn",
		value: "samuel-paluba",
		href: "https://www.linkedin.com/in/samuel-paluba",
	},
	{
		label: "X",
		value: "@PalubaSamuel",
		href: "https://x.com/PalubaSamuel",
	},
	{
		label: "ThinkHome",
		value: "thinkhome.cz",
		href: "https://thinkhome.cz",
	},
	{
		label: "Gravatar",
		value: "samuelpaluba.link",
		href: "https://samuelpaluba.link",
	},
];
---

<Base
	title="Contact"
	description="Contact Samuel Paluba for software, cybersecurity, AI, infrastructure, and ThinkHome work."
>
	<section class="contact-page">
		<header class="contact-header">
			<p class="eyebrow">Contact</p>
			<h1>Start with email.</h1>
			<p>
				For projects, collaboration, questions, or a quick introduction, email is
				the best place to start. I am most interested in practical software, IT
				infrastructure, AI tooling, education systems, and open technology.
			</p>
		</header>

		<div class="contact-list">
			{
				links.map((link) => (
					<a href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined} rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}>
						<span>{link.label}</span>
						<strong>{link.value}</strong>
					</a>
				))
			}
		</div>
	</section>
</Base>

<style>
	.contact-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-2xl) var(--spacing-lg) var(--spacing-4xl);
		display: grid;
		grid-template-columns: minmax(0, 0.85fr) minmax(320px, 1fr);
		gap: var(--spacing-4xl);
	}

	.contact-header h1 {
		max-width: 680px;
		margin: var(--spacing-sm) 0 var(--spacing-lg);
		font-size: var(--font-size-4xl);
		font-weight: 650;
		letter-spacing: 0;
	}

	.contact-header p:not(.eyebrow) {
		max-width: 620px;
		font-size: var(--font-size-lg);
		color: var(--color-muted);
	}

	.eyebrow {
		font-size: var(--font-size-sm);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-accent);
	}

	.contact-list {
		display: grid;
		border-top: 1px solid var(--color-border);
	}

	.contact-list a {
		display: grid;
		grid-template-columns: 120px minmax(0, 1fr);
		gap: var(--spacing-lg);
		align-items: center;
		padding: var(--spacing-lg) 0;
		border-bottom: 1px solid var(--color-border);
		text-decoration: none;
	}

	.contact-list span {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
	}

	.contact-list strong {
		overflow-wrap: anywhere;
		font-size: var(--font-size-lg);
		font-weight: 650;
	}

	.contact-list a:hover strong {
		color: var(--color-accent);
	}

	@media (max-width: 820px) {
		.contact-page {
			grid-template-columns: 1fr;
			gap: var(--spacing-2xl);
		}
	}

	@media (max-width: 520px) {
		.contact-list a {
			grid-template-columns: 1fr;
			gap: var(--spacing-xs);
		}
	}
</style>
