---
import { getEmDashCollection, getSiteSettings } from "emdash";
import Base from "../layouts/Base.astro";
import ProjectCard from "../components/ProjectCard.astro";

const [settings, { entries: featuredProjects, cacheHint }] = await Promise.all([
	getSiteSettings(),
	getEmDashCollection("projects", {
		orderBy: { published_at: "desc" },
		limit: 4,
	}),
]);

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const profileImage =
	"https://0.gravatar.com/avatar/f82d12d78b7a65404663d5091762be0c44c638a8b0c2be16c8a86d6140ec0ef5?size=512";

const focusItems = [
	{
		label: "ThinkHome",
		text: "Building practical IT management, training, and custom software for small and medium-sized businesses.",
	},
	{
		label: "AI tooling",
		text: "Packaging repeatable assistant workflows, API knowledge, and local-model experiments into useful tools.",
	},
	{
		label: "Education systems",
		text: "Exploring cleaner software around Bakalari and other Czech school-system workflows.",
	},
	{
		label: "Open systems",
		text: "Working around open software, hardware, Bitcoin, decentralized systems, and digital freedom.",
	},
];
---

<Base
	description="Cybersecurity student and software builder in Prague, building ThinkHome and practical tools around IT infrastructure, AI workflows, education systems, and open technology."
	image={profileImage}
>
	<section class="hero" aria-labelledby="home-title">
		<div class="hero-media" aria-label="Samuel Paluba">
			<img src={profileImage} alt="Samuel Paluba" loading="eager" />
		</div>
		<div class="hero-copy">
			<p class="hero-kicker">Prague / Cybersecurity / Open tech</p>
			<h1 id="home-title">{settings?.title || "Samuel Paluba"}</h1>
			<p class="hero-lede">
				{settings?.tagline ||
					"Cybersecurity student and software builder in Prague, building ThinkHome and practical tools around IT infrastructure, AI workflows, education systems, and open technology."}
			</p>
			<div class="hero-actions">
				<a class="button primary" href="/work">View work</a>
				<a class="button" href="/contact">Contact</a>
			</div>
		</div>
	</section>

	<section class="focus" aria-labelledby="focus-title">
		<header class="section-header">
			<div>
				<p class="section-kicker">Now</p>
				<h2 id="focus-title">Current focus</h2>
			</div>
		</header>
		<div class="focus-grid">
			{
				focusItems.map((item, index) => (
					<article class="focus-item">
						<span>{String(index + 1).padStart(2, "0")}</span>
						<h3>{item.label}</h3>
						<p>{item.text}</p>
					</article>
				))
			}
		</div>
	</section>

	{
		featuredProjects.length > 0 && (
			<section class="featured" aria-labelledby="featured-title">
				<header class="section-header">
					<div>
						<p class="section-kicker">Selected work</p>
						<h2 id="featured-title">Projects, tools, and experiments</h2>
					</div>
					<a href="/work" class="section-link">
						View all projects
					</a>
				</header>
				<div class="projects-grid">
					{featuredProjects.map((project) => (
						<ProjectCard
							title={project.data.title ?? "Untitled"}
							summary={project.data.summary}
							featuredImage={project.data.featured_image ?? ""}
							href={`/work/${project.id}`}
							client={project.data.client}
							year={project.data.year}
						/>
					))}
				</div>
			</section>
		)
	}

	<section class="values" aria-labelledby="values-title">
		<p class="section-kicker">Values</p>
		<h2 id="values-title">Practical technology should give people more agency.</h2>
		<p>
			I care about open software and hardware, Bitcoin, decentralized systems,
			and digital freedom. The common thread is practical technology that gives
			people more agency, not less.
		</p>
		<a href="/about" class="section-link">Read about Samuel</a>
	</section>
</Base>

<style>
	.hero,
	.focus,
	.featured,
	.values {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding-left: var(--spacing-lg);
		padding-right: var(--spacing-lg);
	}

	.hero {
		padding-top: var(--spacing-3xl);
		padding-bottom: var(--spacing-4xl);
		display: grid;
		grid-template-columns: minmax(240px, 0.64fr) minmax(0, 1.36fr);
		gap: var(--spacing-3xl);
		align-items: center;
	}

	.hero-media {
		width: min(100%, 380px);
		aspect-ratio: 1;
		overflow: hidden;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		background: var(--color-surface);
	}

	.hero-media img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
	}

	.hero-copy {
		max-width: 820px;
	}

	.hero-kicker,
	.section-kicker {
		margin-bottom: var(--spacing-sm);
		font-size: var(--font-size-sm);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-accent);
	}

	.hero-copy h1 {
		max-width: 820px;
		margin-bottom: var(--spacing-lg);
		font-size: 5.5rem;
		font-weight: 650;
		line-height: 0.95;
		letter-spacing: 0;
	}

	.hero-lede {
		max-width: 760px;
		font-size: var(--font-size-xl);
		line-height: 1.45;
		color: var(--color-muted);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-sm);
		margin-top: var(--spacing-xl);
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		padding: 0 var(--spacing-lg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-surface);
		color: var(--color-text);
		font-size: var(--font-size-sm);
		font-weight: 700;
		text-decoration: none;
	}

	.button.primary {
		border-color: var(--color-text);
		background: var(--color-text);
		color: var(--color-bg);
	}

	.focus,
	.featured,
	.values {
		padding-bottom: var(--spacing-4xl);
	}

	.section-header {
		display: flex;
		justify-content: space-between;
		gap: var(--spacing-lg);
		align-items: end;
		margin-bottom: var(--spacing-2xl);
	}

	.section-header h2,
	.values h2 {
		max-width: 760px;
		font-size: var(--font-size-3xl);
		font-weight: 650;
		line-height: 1.08;
		letter-spacing: 0;
	}

	.section-link {
		color: var(--color-text);
		font-size: var(--font-size-sm);
		font-weight: 700;
		text-decoration: none;
		border-bottom: 1px solid currentColor;
	}

	.focus-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: var(--spacing-lg);
	}

	.focus-item {
		padding-top: var(--spacing-lg);
		border-top: 1px solid var(--color-border);
	}

	.focus-item span {
		display: block;
		margin-bottom: var(--spacing-lg);
		color: var(--color-accent);
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
	}

	.focus-item h3 {
		margin-bottom: var(--spacing-sm);
		font-size: var(--font-size-lg);
		font-weight: 650;
	}

	.focus-item p {
		color: var(--color-muted);
		line-height: 1.6;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--spacing-2xl);
	}

	.values {
		max-width: 900px;
		margin-bottom: var(--spacing-2xl);
	}

	.values p:not(.section-kicker) {
		margin: var(--spacing-lg) 0 var(--spacing-xl);
		font-size: var(--font-size-lg);
		line-height: 1.7;
		color: var(--color-muted);
	}

	@media (max-width: 980px) {
		.hero {
			grid-template-columns: minmax(220px, 0.72fr) minmax(0, 1.28fr);
			gap: var(--spacing-2xl);
		}

		.hero-copy h1 {
			font-size: 4.25rem;
		}

		.focus-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 760px) {
		.hero {
			padding-top: var(--spacing-lg);
			padding-bottom: var(--spacing-lg);
			grid-template-columns: 1fr;
			gap: var(--spacing-lg);
		}

		.hero-media {
			width: min(100%, 240px);
		}

		.hero-copy h1 {
			font-size: 3.25rem;
			line-height: 0.96;
		}

		.hero-lede {
			font-size: var(--font-size-lg);
			line-height: 1.42;
		}

		.hero-actions {
			margin-top: var(--spacing-lg);
		}

		.section-header {
			display: grid;
			align-items: start;
		}

		.projects-grid,
		.focus-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
