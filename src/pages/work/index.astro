---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";
import ProjectCard from "../../components/ProjectCard.astro";

const { entries: projects, cacheHint } = await getEmDashCollection("projects", {
	orderBy: { published_at: "desc" },
});

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);
---

<Base
	title="Work"
	description="Public projects, tools, and experiments by Samuel Paluba across software, AI tooling, SDKs, infrastructure, and education systems."
>
	<section class="work-page">
		<header class="work-header">
			<p class="eyebrow">Work</p>
			<h1>Public projects, tools, and experiments.</h1>
			<p>
				A compact view of software, AI tooling, SDKs, infrastructure
				experiments, and education-system work connected to Samuel Paluba and
				ThinkHome.
			</p>
		</header>

		<div class="projects-grid">
			{
				projects.map((project) => (
					<ProjectCard
						title={project.data.title ?? "Untitled"}
						summary={project.data.summary}
						featuredImage={project.data.featured_image ?? ""}
						href={`/work/${project.id}`}
						client={project.data.client}
						year={project.data.year}
					/>
				))
			}
		</div>
	</section>
</Base>

<style>
	.work-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-2xl) var(--spacing-lg) var(--spacing-4xl);
	}

	.work-header {
		max-width: 820px;
		margin-bottom: var(--spacing-3xl);
	}

	.eyebrow {
		margin-bottom: var(--spacing-sm);
		font-size: var(--font-size-sm);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-accent);
	}

	.work-header h1 {
		margin-bottom: var(--spacing-lg);
		font-size: var(--font-size-4xl);
		font-weight: 650;
		letter-spacing: 0;
	}

	.work-header p:not(.eyebrow) {
		font-size: var(--font-size-lg);
		color: var(--color-muted);
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--spacing-2xl);
	}

	@media (max-width: 760px) {
		.projects-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
