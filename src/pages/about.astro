---
import { getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../layouts/Base.astro";

const { entry: page, cacheHint } = await getEmDashEntry("pages", "about");

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);
---

<Base
	title="About"
	description="About Samuel Paluba: cybersecurity student in Prague, builder of ThinkHome, and maker of practical software and AI tools."
>
	<div class="about-page">
		<header class="about-header">
			<p class="eyebrow">About</p>
			<h1 {...page?.edit?.title}>{page?.data?.title || "Samuel Paluba"}</h1>
		</header>

		<section class="about-content" {...page?.edit?.content}>
			{
				page?.data?.content ? (
					<PortableText value={page.data.content} />
				) : (
					<p>
						I am a cybersecurity student in Prague focused on technology,
						cybersecurity, software, infrastructure, and AI.
					</p>
				)
			}
		</section>

		<aside class="about-sidebar">
			<div>
				<h2>Focus</h2>
				<ul>
					<li>Cybersecurity</li>
					<li>Infrastructure</li>
					<li>AI workflows</li>
					<li>Swift and TypeScript software</li>
					<li>Open and decentralized technology</li>
				</ul>
			</div>

			<div>
				<h2>Currently</h2>
				<p>
					Building <a href="https://thinkhome.cz" target="_blank" rel="noopener noreferrer">ThinkHome</a>,
					shipping public tools, and using school projects as a practical
					sandbox for software, infrastructure, and AI workflows.
				</p>
			</div>
		</aside>
	</div>
</Base>

<style>
	.about-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-2xl) var(--spacing-lg) var(--spacing-4xl);
		display: grid;
		grid-template-columns: minmax(0, 1fr) 320px;
		gap: var(--spacing-4xl);
	}

	.about-header {
		grid-column: 1 / -1;
		max-width: 900px;
	}

	.eyebrow {
		margin-bottom: var(--spacing-sm);
		font-size: var(--font-size-sm);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-accent);
	}

	.about-header h1 {
		font-size: var(--font-size-4xl);
		font-weight: 650;
		letter-spacing: 0;
	}

	.about-content {
		max-width: 760px;
		font-size: var(--font-size-lg);
		line-height: 1.7;
		color: var(--color-muted);
	}

	.about-content :global(p) {
		margin-bottom: 1.3em;
	}

	.about-content :global(h2) {
		margin-top: 2em;
		margin-bottom: 0.65em;
		font-size: var(--font-size-2xl);
		color: var(--color-text);
	}

	.about-sidebar {
		position: sticky;
		top: var(--spacing-xl);
		align-self: start;
		display: grid;
		gap: var(--spacing-2xl);
	}

	.about-sidebar div {
		padding-top: var(--spacing-lg);
		border-top: 1px solid var(--color-border);
	}

	.about-sidebar h2 {
		margin-bottom: var(--spacing-md);
		font-size: var(--font-size-lg);
		font-weight: 650;
	}

	.about-sidebar ul {
		list-style: none;
		display: grid;
		gap: var(--spacing-sm);
		color: var(--color-muted);
	}

	.about-sidebar p {
		color: var(--color-muted);
	}

	.about-sidebar a {
		color: var(--color-text);
		font-weight: 700;
		text-decoration: none;
		border-bottom: 1px solid currentColor;
	}

	@media (max-width: 820px) {
		.about-page {
			grid-template-columns: 1fr;
			gap: var(--spacing-2xl);
		}

		.about-sidebar {
			position: static;
		}
	}
</style>
